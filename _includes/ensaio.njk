<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — br.trombin</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #1e2e22;
  --bg-dark: #162318;
  --bg-deeper: #0f1a12;
  --green-mid: #243a28;
  --green-border: #2e4a32;
  --ektar-red: #c8341a;
  --ektar-orange: #d4621e;
  --ektar-amber: #e8a830;
  --cream: #f0e8d0;
  --cream-dim: #b8a880;
  --cream-ghost: #6a5a40;
  --mono: 'Share Tech Mono', monospace;
  --serif: 'Playfair Display', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--cream);
  font-family: var(--serif);
  min-height: 100vh;
  overflow-x: hidden;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 999;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: .05;
  mix-blend-mode: screen;
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .9rem 2rem;
  background: rgba(30,46,34,.94);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--green-border);
}

.logo {
  font-family: var(--mono);
  font-size: .9rem;
  letter-spacing: .2em;
  color: var(--cream);
  text-decoration: none;
  flex-shrink: 0;
}
.logo em { color: var(--ektar-red); font-style: normal; }

.nav-center {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.nav-back {
  font-family: var(--mono);
  font-size: .72rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--cream-dim);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: .4rem;
  transition: color .2s;
}
.nav-back:hover { color: var(--cream); }
.nav-back::before { content: '←'; font-size: .8rem; }

.nav-frame {
  font-family: var(--mono);
  font-size: .65rem;
  letter-spacing: .15em;
  color: var(--ektar-amber);
  opacity: .8;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 1.4rem;
}
.nav-right a {
  font-family: var(--mono);
  font-size: .72rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--cream-dim);
  text-decoration: none;
  transition: color .2s;
}
.nav-right a:hover { color: var(--cream); }
.nav-pill {
  border: 1px solid var(--ektar-red);
  padding: .22rem .7rem;
  color: var(--ektar-red) !important;
}
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  z-index: 101;
}
.nav-hamburger span {
  width: 22px; height: 2px;
  background: var(--cream);
  display: block;
  transition: transform .25s, opacity .2s;
}
.nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-hamburger.open span:nth-child(2) { opacity: 0; }
.nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* HERO */
.article-hero {
  padding-top: 52px;
  position: relative;
}

.hero-film-strip {
  background: #100c07;
  height: 28px;
  display: flex;
  align-items: center;
  padding: 0 6px;
  border-bottom: 2px solid #0d0a05;
  overflow: hidden;
}

.perf {
  width: 14px;
  height: 10px;
  background: #030201;
  border: 1px solid #1a1409;
  border-radius: 2px;
  margin-right: 18px;
  flex-shrink: 0;
}

.hero-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 21/9;
  overflow: hidden;
  background: var(--bg-deeper);
}

.hero-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.hero-stamp {
  position: absolute;
  bottom: 14px;
  right: 18px;
  font-family: var(--mono);
  font-size: clamp(.75rem, 1.1vw, .95rem);
  color: #ff7800;
  letter-spacing: .14em;
  text-shadow: 0 0 6px rgba(255,120,0,.9), 0 0 14px rgba(255,80,0,.5);
  line-height: 1.6;
  text-align: right;
}

.hero-frame-n {
  position: absolute;
  top: 10px;
  left: 14px;
  font-family: var(--mono);
  font-size: .58rem;
  color: rgba(255,140,0,.5);
  letter-spacing: .12em;
}

.hero-film-strip-bot {
  background: var(--bg-deeper);
  height: 28px;
  display: flex;
  align-items: center;
  padding: 0 6px;
  overflow: hidden;
}

/* ENSAIO HEADER */
.ensaio-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 4rem 2rem 6rem;
}

.ensaio-header {
  margin-bottom: 3.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--green-border);
}

.ensaio-eyebrow {
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--ektar-red);
  margin-bottom: 1.2rem;
}

.ensaio-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: 1.08;
  font-style: italic;
  font-weight: 400;
  color: var(--cream);
  margin-bottom: 1.2rem;
}

.ensaio-lead {
  font-family: var(--serif);
  font-size: 1.1rem;
  line-height: 1.8;
  color: var(--cream-dim);
  font-style: italic;
  max-width: 58ch;
}

.ensaio-meta {
  margin-top: 1.2rem;
  display: flex;
  gap: 1.6rem;
  flex-wrap: wrap;
}

.ensaio-meta-item {
  font-family: var(--mono);
  font-size: .58rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--cream-ghost);
}

.ensaio-meta-item span {
  color: var(--cream-dim);
  margin-left: .4rem;
}

/* GRADE DE FOTOS */
.ensaio-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.8rem;
  margin-bottom: 4rem;
}

.foto-card {
  cursor: pointer;
  display: flex;
  flex-direction: column;
}

.foto-frame {
  position: relative;
  aspect-ratio: 3/2;
  overflow: hidden;
  background: var(--bg-deeper);
  border: 3px solid #100c07;
  border-bottom: none;
}

.foto-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .35s;
}

.foto-card:hover .foto-frame img {
  transform: scale(1.02);
}

/* perf decorativa no canto */
.foto-frame::before {
  content: '';
  position: absolute;
  top: 6px;
  right: 6px;
  width: 10px;
  height: 7px;
  background: #030201;
  border: 1px solid #1a1409;
  border-radius: 1px;
  z-index: 1;
  pointer-events: none;
}

.foto-num {
  position: absolute;
  bottom: 8px;
  left: 8px;
  font-family: var(--mono);
  font-size: .52rem;
  color: var(--ektar-amber);
  letter-spacing: .1em;
  text-shadow: 0 0 4px rgba(0,0,0,.8);
  pointer-events: none;
}

.foto-caption {
  background: #100c07;
  border: 3px solid #100c07;
  border-top: none;
  padding: .4rem .6rem;
  font-family: var(--mono);
  font-size: .52rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ektar-orange);
  min-height: 1.8rem;
  line-height: 1.5;
}

/* NAV ENTRE TEXTOS */
.article-nav {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid var(--green-border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.article-nav-link {
  text-decoration: none;
  padding: 1rem;
  border: 1px solid var(--green-border);
  transition: border-color .2s, background .2s;
  display: block;
}

.article-nav-link:hover {
  border-color: var(--cream-ghost);
  background: rgba(255,255,255,.02);
}

.article-nav-link.next { text-align: right; }

.anl-dir {
  font-family: var(--mono);
  font-size: .52rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ektar-red);
  margin-bottom: .4rem;
}

.anl-title {
  font-family: var(--serif);
  font-size: .88rem;
  font-style: italic;
  color: var(--cream-dim);
  line-height: 1.3;
}

/* FOOTER */
footer {
  border-top: 1px solid var(--green-border);
  padding: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-logo {
  font-family: var(--mono);
  font-size: .82rem;
  letter-spacing: .15em;
  color: var(--cream);
}
.footer-logo em { color: var(--ektar-red); font-style: normal; }

.footer-links { display: flex; gap: 1.5rem; }
.footer-links a {
  font-family: var(--mono);
  font-size: .58rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--cream-ghost);
  text-decoration: none;
  transition: color .2s;
}
.footer-links a:hover { color: var(--cream); }

/* LIGHTBOX */
.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(10,14,11,.96);
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.lightbox.open { display: flex; }

.lightbox-img-wrap {
  position: relative;
  max-width: 90vw;
  max-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lightbox-img-wrap img {
  max-width: 90vw;
  max-height: 80vh;
  object-fit: contain;
  display: block;
}

.lightbox-close {
  position: fixed;
  top: 1.2rem;
  right: 1.6rem;
  background: none;
  border: none;
  color: var(--cream-dim);
  font-family: var(--mono);
  font-size: 1.4rem;
  cursor: pointer;
  z-index: 1;
  padding: .4rem;
  transition: color .2s;
}
.lightbox-close:hover { color: var(--cream); }

.lightbox-nav {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: var(--cream-dim);
  font-family: var(--mono);
  font-size: 1.6rem;
  cursor: pointer;
  padding: 1rem;
  transition: color .2s;
  z-index: 1;
}
.lightbox-nav:hover { color: var(--cream); }
.lightbox-prev { left: 1rem; }
.lightbox-next { right: 1rem; }

.lightbox-meta {
  margin-top: 1.2rem;
  text-align: center;
}

.lightbox-num {
  font-family: var(--mono);
  font-size: .58rem;
  letter-spacing: .18em;
  color: var(--ektar-amber);
  margin-bottom: .3rem;
}

.lightbox-caption {
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--cream-ghost);
  min-height: 1rem;
}

@media (max-width: 800px) {
  nav { padding: .8rem 1.2rem; }
  .nav-center { display: none; }
  .nav-hamburger { display: flex; }
  .nav-right {
    display: none;
    position: fixed;
    top: 49px; left: 0; right: 0;
    background: rgba(22,35,24,.98);
    flex-direction: column;
    align-items: flex-start;
    padding: 1.8rem 2rem;
    gap: 1.4rem;
    border-bottom: 1px solid #243a28;
    z-index: 102;
  }
  .nav-right.open { display: flex; }
  .nav-right a { font-size: .9rem; letter-spacing: .14em; }
  .ensaio-wrap { padding: 2.5rem 1.2rem 4rem; }
  .ensaio-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  footer { flex-direction: column; gap: 1rem; text-align: center; }
  .lightbox-nav { font-size: 1.2rem; padding: .6rem; }
}

@media (max-width: 480px) {
  .ensaio-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<nav aria-label="Navegação principal">
  <a href="{{ '/' | url }}" class="logo" aria-label="br.trombin — página inicial">br<em>.</em>trombin</a>
  <div class="nav-center">
    <a href="{{ '/' | url }}" class="nav-back">contact sheet</a>
    <span class="nav-frame">frame {{ frameNumber }} / 99exp</span>
  </div>
  <div class="nav-right" id="nav-menu">
    <a href="{{ '/sobre/' | url }}">sobre</a>
    <a href="{{ '/galeria.html' | url }}">galeria</a>
    <a href="https://naocabe.substack.com" target="_blank" rel="noopener" class="nav-pill">Substack</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank" rel="noopener" class="nav-pill">Instagram</a>
  </div>
  <button class="nav-hamburger" id="nav-toggle" aria-label="abrir menu" aria-expanded="false" aria-controls="nav-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="article-hero">
  <div class="hero-film-strip" id="perfs-top"></div>
  <div class="hero-img-wrap">
    {% if hero_image %}
    <img src="{{ hero_image | url }}" alt="{{ title }}">
    {% endif %}
    <span class="hero-frame-n">{{ frameNumber }}</span>
    <div class="hero-stamp">
      {% if location %}{{ location }}<br>{% endif %}
      {{ date | dateStamp }}{% if film %}<br>{{ film }}{% endif %}
    </div>
  </div>
  <div class="hero-film-strip-bot" id="perfs-bot"></div>
</div>

<div class="ensaio-wrap">

  <header class="ensaio-header">
    <p class="ensaio-eyebrow">ensaio &middot; {{ date | dateLong }}</p>
    <h1 class="ensaio-title">{{ title }}</h1>
    {% if lead %}
    <p class="ensaio-lead">{{ lead }}</p>
    {% endif %}
    {% if camera or film %}
    <div class="ensaio-meta">
      {% if camera %}<div class="ensaio-meta-item">câmera<span>{{ camera }}</span></div>{% endif %}
      {% if film %}<div class="ensaio-meta-item">filme<span>{{ film }}</span></div>{% endif %}
      {% if location %}<div class="ensaio-meta-item">local<span>{{ location }}</span></div>{% endif %}
    </div>
    {% endif %}
  </header>

  {% if images %}
  <div class="ensaio-grid" id="ensaio-grid">
    {% for img in images %}
    <div class="foto-card" data-index="{{ loop.index0 }}" role="button" tabindex="0" aria-label="abrir foto {{ loop.index }}">
      <div class="foto-frame">
        <img src="{{ img.src | url }}" alt="{{ img.caption or (title + ' — foto ' + loop.index) }}" loading="lazy">
        <span class="foto-num">{% if loop.index < 10 %}0{{ loop.index }}{% else %}{{ loop.index }}{% endif %}</span>
      </div>
      <div class="foto-caption">{% if img.caption %}{{ img.caption }}{% endif %}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <nav class="article-nav">
    {% if prevArticle %}
    <a href="{{ prevArticle.url }}" class="article-nav-link prev">
      <p class="anl-dir">← anterior</p>
      <p class="anl-title">{{ prevArticle.data.title }}</p>
    </a>
    {% else %}
    <div></div>
    {% endif %}
    {% if nextArticle %}
    <a href="{{ nextArticle.url }}" class="article-nav-link next">
      <p class="anl-dir">próximo →</p>
      <p class="anl-title">{{ nextArticle.data.title }}</p>
    </a>
    {% endif %}
  </nav>

</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visualizador de fotos">
  <button class="lightbox-close" id="lb-close" aria-label="fechar">✕</button>
  <button class="lightbox-nav lightbox-prev" id="lb-prev" aria-label="foto anterior">‹</button>
  <div class="lightbox-img-wrap">
    <img id="lb-img" src="" alt="">
  </div>
  <button class="lightbox-nav lightbox-next" id="lb-next" aria-label="próxima foto">›</button>
  <div class="lightbox-meta">
    <p class="lightbox-num" id="lb-num"></p>
    <p class="lightbox-caption" id="lb-caption"></p>
  </div>
</div>

<footer>
  <span class="footer-logo">br<em>.</em>trombin</span>
  <div class="footer-links">
    <a href="{{ '/' | url }}">contact sheet</a>
    <a href="https://naocabe.substack.com" target="_blank">Substack</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank">Instagram</a>
  </div>
</footer>

<script>
// PERFS
function makePerfs(id) {
  var el = document.getElementById(id);
  if (!el) return;
  var n = Math.ceil(window.innerWidth / 32) + 2;
  el.innerHTML = Array(n).fill('<div class="perf"></div>').join('');
}
makePerfs('perfs-top');
makePerfs('perfs-bot');
window.addEventListener('resize', function() { makePerfs('perfs-top'); makePerfs('perfs-bot'); });

// NAV HAMBURGER
(function() {
  var toggle = document.getElementById("nav-toggle");
  var menu   = document.getElementById("nav-menu");
  if (!toggle || !menu) return;
  toggle.addEventListener("click", function() {
    var open = menu.classList.toggle("open");
    toggle.classList.toggle("open", open);
    toggle.setAttribute("aria-expanded", String(open));
  });
  document.addEventListener("click", function(e) {
    if (!menu.contains(e.target) && !toggle.contains(e.target)) {
      menu.classList.remove("open");
      toggle.classList.remove("open");
      toggle.setAttribute("aria-expanded", "false");
    }
  });
  menu.querySelectorAll("a").forEach(function(a) {
    a.addEventListener("click", function() {
      menu.classList.remove("open");
      toggle.classList.remove("open");
      toggle.setAttribute("aria-expanded", "false");
    });
  });
})();

// LIGHTBOX
(function() {
  var images = [];
  var current = 0;
  var lb      = document.getElementById("lightbox");
  var lbImg   = document.getElementById("lb-img");
  var lbNum   = document.getElementById("lb-num");
  var lbCap   = document.getElementById("lb-caption");

  // Coleta dados das fotos
  document.querySelectorAll(".foto-card").forEach(function(card, i) {
    var img = card.querySelector("img");
    var cap = card.querySelector(".foto-caption");
    images.push({
      src:     img ? img.src : "",
      alt:     img ? img.alt : "",
      caption: cap ? cap.textContent.trim() : ""
    });
  });

  function open(idx) {
    current = (idx + images.length) % images.length;
    lbImg.src = images[current].src;
    lbImg.alt = images[current].alt;
    lbNum.textContent = (current + 1) + " / " + images.length;
    lbCap.textContent = images[current].caption;
    lb.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function close() {
    lb.classList.remove("open");
    lbImg.src = "";
    document.body.style.overflow = "";
  }

  // Clique nos cards
  document.querySelectorAll(".foto-card").forEach(function(card, i) {
    card.addEventListener("click", function() { open(i); });
    card.addEventListener("keydown", function(e) { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); open(i); } });
  });

  document.getElementById("lb-close").addEventListener("click", close);
  document.getElementById("lb-prev").addEventListener("click", function() { open(current - 1); });
  document.getElementById("lb-next").addEventListener("click", function() { open(current + 1); });

  lb.addEventListener("click", function(e) {
    if (e.target === lb) close();
  });

  document.addEventListener("keydown", function(e) {
    if (!lb.classList.contains("open")) return;
    if (e.key === "Escape")     close();
    if (e.key === "ArrowLeft")  open(current - 1);
    if (e.key === "ArrowRight") open(current + 1);
  });
})();
</script>
</body>
</html>
