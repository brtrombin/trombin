<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — br.trombin</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #1e2e22;
  --bg-dark: #162318;
  --bg-deeper: #0f1a12;
  --green-mid: #243a28;
  --green-border: #2e4a32;
  --ektar-red: #c8341a;
  --ektar-orange: #d4621e;
  --ektar-amber: #e8a830;
  --cream: #f0e8d0;
  --cream-dim: #b8a880;
  --cream-ghost: #6a5a40;
  --mono: 'Share Tech Mono', monospace;
  --serif: 'Playfair Display', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--cream);
  font-family: var(--serif);
  min-height: 100vh;
  overflow-x: hidden;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 999;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: .05;
  mix-blend-mode: screen;
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .9rem 2rem;
  background: rgba(30,46,34,.94);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--green-border);
}

.logo {
  font-family: var(--mono);
  font-size: .9rem;
  letter-spacing: .2em;
  color: var(--cream);
  text-decoration: none;
  flex-shrink: 0;
}
.logo em { color: var(--ektar-red); font-style: normal; }

.nav-center {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.nav-back {
  font-family: var(--mono);
  font-size: .72rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--cream-dim);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: .4rem;
  transition: color .2s;
}
.nav-back:hover { color: var(--cream); }
.nav-back::before { content: '←'; font-size: .8rem; }

.nav-frame {
  font-family: var(--mono);
  font-size: .65rem;
  letter-spacing: .15em;
  color: var(--ektar-amber);
  opacity: .8;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 1.4rem;
}
.nav-right a {
  font-family: var(--mono);
  font-size: .72rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--cream-dim);
  text-decoration: none;
  transition: color .2s;
}
.nav-right a:hover { color: var(--cream); }
.nav-pill {
  border: 1px solid var(--ektar-red);
  padding: .22rem .7rem;
  color: var(--ektar-red) !important;
}

/* HERO */
.article-hero {
  padding-top: 52px;
  position: relative;
}

.hero-film-strip {
  background: #100c07;
  height: 28px;
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 6px;
  border-bottom: 2px solid #0d0a05;
  overflow: hidden;
}

.perf {
  width: 14px;
  height: 10px;
  background: #030201;
  border: 1px solid #1a1409;
  border-radius: 2px;
  margin-right: 18px;
  flex-shrink: 0;
}

.hero-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 21/9;
  overflow: hidden;
  background: var(--bg-deeper);
  border-top: 3px solid var(--bg-deeper);
  border-bottom: 3px solid var(--bg-deeper);
}

.hero-img-wrap .ph {
  width: 100%;
  height: 100%;
}

.hero-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(1.1) saturate(1.2);
  display: block;
}

.hero-stamp {
  position: absolute;
  bottom: 14px;
  right: 18px;
  font-family: var(--mono);
  font-size: clamp(.75rem, 1.1vw, .95rem);
  color: #ff7800;
  letter-spacing: .14em;
  text-shadow: 0 0 6px rgba(255,120,0,.9), 0 0 14px rgba(255,80,0,.5);
  line-height: 1.6;
  text-align: right;
}

.hero-frame-n {
  position: absolute;
  top: 10px;
  left: 14px;
  font-family: var(--mono);
  font-size: .58rem;
  color: rgba(255,140,0,.5);
  letter-spacing: .12em;
}

.hero-film-strip-bot {
  background: var(--bg-deeper);
  height: 28px;
  display: flex;
  align-items: center;
  padding: 0 6px;
  overflow: hidden;
}

/* ARTICLE — duas colunas */
.article-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 4rem 2rem 6rem;
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: 4rem;
  align-items: start;
}

.article-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--green-border);
}

.article-eyebrow {
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--ektar-red);
  margin-bottom: 1.2rem;
}

.article-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: 1.08;
  font-style: italic;
  font-weight: 400;
  color: var(--cream);
  margin-bottom: 1.2rem;
}

.article-lead {
  font-family: var(--serif);
  font-size: 1.1rem;
  line-height: 1.8;
  color: var(--cream-dim);
  font-style: italic;
  max-width: 58ch;
}

/* headings dentro do corpo */
.article-body h2 {
  font-family: var(--mono);
  font-size: .62rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  font-weight: 400;
  color: var(--ektar-orange);
  line-height: 1.4;
  margin-top: 3.5rem;
  margin-bottom: 1rem;
  max-width: 62ch;
}

.article-body h3 {
  font-family: var(--mono);
  font-size: .7rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ektar-red);
  line-height: 1.4;
  margin-top: 3rem;
  margin-bottom: .9rem;
  max-width: 62ch;
}

/* body text */
.article-body p {
  font-family: var(--serif);
  font-size: 1rem;
  line-height: 1.9;
  color: var(--cream-dim);
  margin-bottom: 1.6rem;
  max-width: 62ch;
}

.article-body p:first-child::first-letter {
  font-size: 3.5rem;
  line-height: .8;
  float: left;
  margin: .05em .12em -.05em 0;
  color: var(--ektar-red);
  font-style: italic;
  font-weight: 700;
}

/* foto intercalada */
.inline-photo {
  margin: 2.5rem 0;
  position: relative;
}

.inline-photo-frame {
  background: var(--bg-deeper);
  padding: 4px;
  border: 2px solid var(--bg-deeper);
  position: relative;
}

.inline-photo-frame img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
  filter: contrast(1.08) saturate(1.15);
}

.inline-photo-stamp {
  position: absolute;
  bottom: 10px;
  right: 10px;
  font-family: var(--mono);
  font-size: .55rem;
  color: #ff8c00;
  letter-spacing: .1em;
  text-shadow: 0 0 6px rgba(255,140,0,.5);
  line-height: 1.5;
  text-align: right;
}

.inline-photo-frame-n {
  position: absolute;
  top: 8px;
  left: 10px;
  font-family: var(--mono);
  font-size: .52rem;
  color: rgba(255,140,0,.45);
  letter-spacing: .1em;
}

.photo-caption {
  margin-top: .8rem;
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .12em;
  color: var(--cream-ghost);
  text-transform: uppercase;
  padding-left: 4px;
}

.inline-photo.wide {
  margin-left: -2rem;
  margin-right: -2rem;
}

/* SIDEBAR */
.article-sidebar {
  position: sticky;
  top: 80px;
}

.sidebar-block {
  margin-bottom: 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--green-border);
}

.sidebar-block:last-child { border-bottom: none; }

.sidebar-label {
  font-family: var(--mono);
  font-size: .55rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--ektar-red);
  margin-bottom: 1rem;
}

.sidebar-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: .5rem;
}

.sidebar-meta-key {
  font-family: var(--mono);
  font-size: .58rem;
  letter-spacing: .1em;
  color: var(--cream-ghost);
  text-transform: uppercase;
}

.sidebar-meta-val {
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .08em;
  color: var(--cream-dim);
  text-align: right;
}

.sidebar-note {
  font-family: var(--serif);
  font-size: .82rem;
  line-height: 1.75;
  color: var(--cream-ghost);
  font-style: italic;
}

.sidebar-tags {
  display: flex;
  flex-wrap: wrap;
  gap: .4rem;
}

.tag {
  font-family: var(--mono);
  font-size: .65rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--cream-dim);
  border: 1px solid var(--green-border);
  padding: .28rem .7rem;
  text-decoration: none;
  cursor: pointer;
  transition: color .2s, border-color .2s;
}
.tag:hover {
  color: var(--cream);
  border-color: var(--cream-dim);
}

.tag.red {
  color: var(--ektar-red);
  border-color: var(--ektar-red);
}
.tag.red:hover {
  color: var(--cream);
  border-color: var(--cream-dim);
}

/* nav entre textos */
.article-nav {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid var(--green-border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.article-nav-link {
  text-decoration: none;
  padding: 1rem;
  border: 1px solid var(--green-border);
  transition: border-color .2s, background .2s;
  display: block;
}

.article-nav-link:hover {
  border-color: var(--cream-ghost);
  background: rgba(255,255,255,.02);
}

.article-nav-link.next { text-align: right; }

.anl-dir {
  font-family: var(--mono);
  font-size: .52rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ektar-red);
  margin-bottom: .4rem;
}

.anl-title {
  font-family: var(--serif);
  font-size: .88rem;
  font-style: italic;
  color: var(--cream-dim);
  line-height: 1.3;
}

footer {
  border-top: 1px solid var(--green-border);
  padding: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-logo {
  font-family: var(--mono);
  font-size: .82rem;
  letter-spacing: .15em;
  color: var(--cream);
}
.footer-logo em { color: var(--ektar-red); font-style: normal; }

.footer-links { display: flex; gap: 1.5rem; }
.footer-links a {
  font-family: var(--mono);
  font-size: .58rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--cream-ghost);
  text-decoration: none;
  transition: color .2s;
}
.footer-links a:hover { color: var(--cream); }

@media (max-width: 800px) {
  nav { padding: .8rem 1.2rem; }
  .nav-center { display: none; }
  .nav-right a { font-size: .58rem; letter-spacing: .1em; }
  .article-wrap {
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 2.5rem 1.2rem 4rem;
  }
  .article-sidebar { position: static; }
  .hero-img-wrap { aspect-ratio: 4/3; }
  .inline-photo.wide { margin-left: -1.2rem; margin-right: -1.2rem; }
  footer { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>
</head>
<body>

<nav>
  <a href="{{ '/' | url }}" class="logo">br<em>.</em>trombin</a>
  <div class="nav-center">
    <a href="{{ '/' | url }}" class="nav-back">contact sheet</a>
    <span class="nav-frame">frame {{ frameNumber }} / 99exp</span>
  </div>
  <div class="nav-right">
    <a href="{{ '/sobre/' | url }}">sobre</a>
    <a href="{{ '/galeria.html' | url }}">galeria</a>
    <a href="https://naocabe.substack.com" target="_blank" class="nav-pill">Substack</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank" class="nav-pill">Instagram</a>
  </div>
</nav>

<div class="article-hero">
  <div class="hero-film-strip" id="perfs-top"></div>
  <div class="hero-img-wrap">
    {% if hero_image %}
    <img src="{{ hero_image | url }}" alt="{{ title }}">
    {% else %}
    <div class="ph" style="background:{{ hero_gradient | default('linear-gradient(160deg,#1a3a5c 0%,#2e6a9e 30%,#6a8a5a 60%,#c8621e 85%,#c8341a 100%)') }}"></div>
    {% endif %}
    <span class="hero-frame-n">{{ frameNumber }}</span>
    <div class="hero-stamp">
      {% if location %}{{ location }}<br>{% endif %}
      {{ date | dateStamp }}{% if aperture or speed %}<br>{{ aperture }}{% if aperture and speed %}&nbsp;&nbsp;{% endif %}{{ speed }}{% endif %}
    </div>
  </div>
  <div class="hero-film-strip-bot" id="perfs-bot"></div>
</div>

<div class="article-wrap">
  <main class="article-main">

    <header class="article-header">
      <p class="article-eyebrow">{{ type | default("leitura") }} &middot; {{ date | dateLong }}</p>
      <h1 class="article-title">{{ title }}</h1>
      {% if lead %}
      <p class="article-lead">{{ lead }}</p>
      {% endif %}
    </header>

    <div class="article-body">
      {{ content | safe }}
    </div>

    <nav class="article-nav">
      {% if prevArticle %}
      <a href="{{ prevArticle.url }}" class="article-nav-link prev">
        <p class="anl-dir">← anterior</p>
        <p class="anl-title">{{ prevArticle.data.title }}</p>
      </a>
      {% else %}
      <div></div>
      {% endif %}
      {% if nextArticle %}
      <a href="{{ nextArticle.url }}" class="article-nav-link next">
        <p class="anl-dir">próximo →</p>
        <p class="anl-title">{{ nextArticle.data.title }}</p>
      </a>
      {% endif %}
    </nav>

  </main>

  <aside class="article-sidebar">

    <div class="sidebar-block">
      <p class="sidebar-label">exposição</p>
      {% if camera %}
      <div class="sidebar-meta-row">
        <span class="sidebar-meta-key">câmera</span>
        <span class="sidebar-meta-val">{{ camera }}</span>
      </div>
      {% endif %}
      {% if film %}
      <div class="sidebar-meta-row">
        <span class="sidebar-meta-key">filme</span>
        <span class="sidebar-meta-val">{{ film }}</span>
      </div>
      {% endif %}
      {% if aperture %}
      <div class="sidebar-meta-row">
        <span class="sidebar-meta-key">abertura</span>
        <span class="sidebar-meta-val">{{ aperture }}</span>
      </div>
      {% endif %}
      {% if speed %}
      <div class="sidebar-meta-row">
        <span class="sidebar-meta-key">velocidade</span>
        <span class="sidebar-meta-val">{{ speed }}</span>
      </div>
      {% endif %}
      {% if location %}
      <div class="sidebar-meta-row">
        <span class="sidebar-meta-key">local</span>
        <span class="sidebar-meta-val">{{ location }}</span>
      </div>
      {% endif %}
      <div class="sidebar-meta-row">
        <span class="sidebar-meta-key">data</span>
        <span class="sidebar-meta-val">{{ date | dateFormattedPT }}</span>
      </div>
    </div>

    {% if author_note %}
    <div class="sidebar-block">
      <p class="sidebar-label">nota do autor</p>
      <p class="sidebar-note">{{ author_note }}</p>
    </div>
    {% endif %}

    {% if themes %}
    <div class="sidebar-block">
      <p class="sidebar-label">temas</p>
      <div class="sidebar-tags">
        {% for theme in themes %}
        <a href="{{ '/galeria.html' | url }}?theme={{ theme }}" class="tag{% if loop.first %} red{% endif %}">{{ theme }}</a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if substack_url %}
    <div class="sidebar-block">
      <p class="sidebar-label">também em</p>
      <div class="sidebar-meta-row">
        <a href="{{ substack_url }}" target="_blank" style="font-family:var(--mono);font-size:.58rem;letter-spacing:.1em;color:var(--ektar-red);text-decoration:none;text-transform:uppercase">Não Cabia · Substack ↗</a>
      </div>
    </div>
    {% endif %}

  </aside>
</div>

<footer>
  <span class="footer-logo">br<em>.</em>trombin</span>
  <div class="footer-links">
    <a href="{{ '/' | url }}">contact sheet</a>
    <a href="https://naocabe.substack.com" target="_blank">Substack</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank">Instagram</a>
  </div>
</footer>

<script>
function makePerfs(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const n = Math.ceil(window.innerWidth / 32) + 2;
  el.innerHTML = Array(n).fill('<div class="perf"></div>').join('');
}
makePerfs('perfs-top');
makePerfs('perfs-bot');
window.addEventListener('resize', () => { makePerfs('perfs-top'); makePerfs('perfs-bot'); });
</script>
</body>
</html>
