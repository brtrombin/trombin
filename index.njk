---
permalink: /
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>br.trombin</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
<style>
:root {
  /* Magazine palette — editorial / paper */
  --paper:       #f4edd8;
  --paper-dark:  #ede4cc;
  --ink:         #1a1210;
  --ink-mid:     #3a2e24;
  --ink-dim:     #8a7a66;
  --rule:        #c8b898;
  --accent:      #c8341a;
  --accent-warm: #d4621e;
  --kodak:       #e8b830;
  /* Dark — nav, capa, temas, footer */
  --dark-bg:     #1a1210;
  --dark-mid:    #2a1e14;
  --dark-border: #3a2a1c;
  --perf-hole:   #000;
  /* Typography */
  --mono:  'Share Tech Mono', monospace;
  --serif: 'Playfair Display', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--dark-bg);
  color: var(--ink);
  font-family: var(--mono);
  min-height: 100vh;
  overflow-x: hidden;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 999;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: .04;
  mix-blend-mode: multiply;
}

/* ── NAV ────────────────────────────────────────────────────────────── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .9rem 2rem;
  background: rgba(26,18,16,.96);
  backdrop-filter: blur(6px);
  border-bottom: 1px solid var(--dark-border);
}

.logo {
  font-family: var(--mono);
  font-size: .95rem;
  letter-spacing: .2em;
  color: var(--paper);
  text-decoration: none;
}
.logo em { color: var(--accent); font-style: normal; }

.nav-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}
.nav-right a {
  font-family: var(--mono);
  font-size: .72rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ink-dim);
  text-decoration: none;
  transition: color .2s;
}
.nav-right a:hover { color: var(--paper); }
.nav-pill {
  border: 1px solid var(--dark-border);
  padding: .22rem .7rem;
  color: var(--accent) !important;
  border-color: var(--accent) !important;
}

/* ── CAPA (magazine cover) ──────────────────────────────────────────── */
.cover {
  position: relative;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
  background: var(--dark-bg);
}

/* perf strips — top & bottom accent */
.cover-perfs {
  position: absolute;
  top: 52px;
  left: 0; right: 0;
  height: 20px;
  background: var(--dark-mid);
  z-index: 5;
  display: flex;
  align-items: center;
  padding: 0 4px;
  overflow: hidden;
  gap: 0;
}
.cover-perfs-bot {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  height: 20px;
  background: var(--dark-mid);
  z-index: 5;
  display: flex;
  align-items: center;
  padding: 0 4px;
  overflow: hidden;
  gap: 0;
}
.perf {
  width: 14px;
  height: 10px;
  background: var(--perf-hole);
  border: 1px solid #1a1408;
  border-radius: 2px;
  margin-right: 18px;
  flex-shrink: 0;
}

/* full-bleed photo */
.cover-photo {
  position: absolute;
  inset: 0;
  z-index: 1;
}
.cover-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(1.08) saturate(1.2);
  display: block;
}
.cover-photo::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(26,18,16,.78) 0%,
    rgba(26,18,16,.08) 42%,
    rgba(26,18,16,.88) 100%
  );
}

/* masthead — top of cover */
.cover-masthead {
  position: absolute;
  top: 0;
  left: 0; right: 0;
  z-index: 10;
  padding: 5rem 3rem 1.2rem;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  border-bottom: 1px solid rgba(232,184,48,.35);
}
.masthead-name {
  font-family: var(--serif);
  font-size: clamp(2rem, 4.5vw, 4.2rem);
  font-weight: 700;
  font-style: italic;
  color: var(--paper);
  letter-spacing: -.02em;
  line-height: 1;
  text-shadow: 0 2px 12px rgba(0,0,0,.5);
}
.masthead-name em { font-style: normal; color: var(--accent); }
.masthead-meta {
  font-family: var(--mono);
  font-size: .55rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(244,237,216,.5);
  text-align: right;
  line-height: 2;
}

/* central editorial headline */
.cover-headline {
  position: absolute;
  bottom: 28%;
  left: 0; right: 0;
  z-index: 10;
  padding: 0 3rem;
  text-align: center;
}
.cover-kicker {
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: var(--kodak);
  margin-bottom: .9rem;
  display: block;
}
.cover-title {
  font-family: var(--serif);
  font-size: clamp(2.6rem, 6.5vw, 6rem);
  font-weight: 700;
  font-style: italic;
  color: var(--paper);
  line-height: 1.0;
  letter-spacing: -.02em;
  text-shadow: 0 4px 24px rgba(0,0,0,.55);
  margin-bottom: 1rem;
}
.cover-deck {
  font-family: var(--serif);
  font-size: clamp(.88rem, 1.4vw, 1.05rem);
  color: rgba(244,237,216,.78);
  font-style: italic;
  max-width: 52ch;
  margin: 0 auto;
  line-height: 1.55;
}

/* cover lines — base of cover */
.cover-lines {
  position: absolute;
  bottom: 2.8rem;
  left: 0; right: 0;
  z-index: 10;
  padding: 0 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}
.cover-cta {
  display: inline-block;
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--dark-bg);
  background: var(--paper);
  padding: .65rem 1.5rem;
  text-decoration: none;
  flex-shrink: 0;
  transition: background .2s;
}
.cover-cta:hover { background: var(--kodak); }

.cover-teasers {
  display: flex;
  gap: 2.5rem;
  overflow: hidden;
}
.cover-teaser {
  font-family: var(--mono);
  font-size: .54rem;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: rgba(244,237,216,.5);
  border-left: 2px solid var(--accent);
  padding-left: .6rem;
  line-height: 1.7;
  max-width: 20ch;
  text-decoration: none;
  transition: color .2s;
}
.cover-teaser:hover { color: var(--paper); }
.cover-teaser strong {
  display: block;
  color: rgba(244,237,216,.75);
  font-weight: normal;
}

/* ektar stamp */
.ektar-stamp {
  position: absolute;
  bottom: 3.5rem;
  right: 3rem;
  z-index: 11;
  font-family: var(--mono);
  font-size: clamp(.58rem, .85vw, .78rem);
  color: rgba(255,120,0,.7);
  letter-spacing: .14em;
  text-shadow: 0 0 6px rgba(255,120,0,.55), 0 0 14px rgba(255,80,0,.3);
  line-height: 1.7;
  text-align: right;
}

/* ── DESTAQUE DA EDIÇÃO ─────────────────────────────────────────────── */
.featured-section {
  background: var(--paper);
  border-top: 4px solid var(--ink);
  padding: 4rem 3rem;
}
.dept-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 3rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--rule);
}
.dept-label {
  font-family: var(--mono);
  font-size: .56rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--accent);
  white-space: nowrap;
}
.dept-line { flex: 1; height: 1px; background: var(--rule); }
.dept-right {
  font-family: var(--mono);
  font-size: .52rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ink-dim);
  white-space: nowrap;
}

.featured-spread {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 3rem;
  align-items: start;
}

/* photo column */
.featured-photo-frame {
  background: var(--ink);
  padding: 5px;
  margin-bottom: .8rem;
}
.featured-photo-frame img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
  filter: contrast(1.1) saturate(1.15);
}
.featured-photo-placeholder {
  width: 100%;
  aspect-ratio: 4/3;
}
.featured-caption {
  font-family: var(--mono);
  font-size: .56rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ink-dim);
  line-height: 1.8;
  border-left: 2px solid var(--rule);
  padding-left: .5rem;
}

/* text column */
.featured-text-col {
  border-left: 1px solid var(--rule);
  padding-left: 3rem;
}
.featured-eyebrow {
  font-family: var(--mono);
  font-size: .54rem;
  letter-spacing: .26em;
  text-transform: uppercase;
  color: var(--ink-dim);
  margin-bottom: 1rem;
  display: block;
}
.featured-title {
  font-family: var(--serif);
  font-size: clamp(1.9rem, 3.2vw, 3rem);
  font-weight: 700;
  font-style: italic;
  color: var(--ink);
  line-height: 1.08;
  letter-spacing: -.02em;
  margin-bottom: 1.5rem;
}
.featured-title::after {
  content: '';
  display: block;
  width: 2.5rem;
  height: 3px;
  background: var(--accent);
  margin-top: 1.1rem;
}
.featured-lead {
  font-family: var(--serif);
  font-size: .98rem;
  line-height: 1.88;
  color: var(--ink-mid);
  font-style: italic;
  margin-bottom: 2rem;
}
.featured-byline {
  font-family: var(--mono);
  font-size: .56rem;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--ink-dim);
  margin-bottom: 2.5rem;
  display: flex;
  align-items: center;
  gap: .8rem;
}
.featured-byline::before {
  content: '';
  display: inline-block;
  width: 1.5rem;
  height: 1px;
  background: var(--ink-dim);
}
.btn-mag {
  display: inline-block;
  font-family: var(--mono);
  font-size: .6rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--paper);
  background: var(--ink);
  padding: .65rem 1.5rem;
  text-decoration: none;
  border: 2px solid var(--ink);
  transition: background .2s, border-color .2s;
}
.btn-mag:hover { background: var(--accent); border-color: var(--accent); }

/* ── ARQUIVO ────────────────────────────────────────────────────────── */
.arquivo-section {
  background: var(--paper);
  border-top: 4px solid var(--ink);
  padding: 3rem 3rem 5rem;
}

.arquivo-masthead {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: end;
  border-bottom: 3px solid var(--ink);
  padding-bottom: .5rem;
  margin-bottom: 3rem;
}
.arquivo-masthead-title {
  font-family: var(--serif);
  font-size: clamp(3rem, 7vw, 6.5rem);
  font-weight: 700;
  color: var(--ink);
  line-height: .88;
  letter-spacing: -.04em;
}
.arquivo-masthead-meta {
  font-family: var(--mono);
  font-size: .52rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--ink-dim);
  text-align: right;
  line-height: 2;
  padding-bottom: .2rem;
}

/* row layouts */
.arquivo-row-hero {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 2rem;
  margin-bottom: 2.5rem;
  align-items: start;
}
.arquivo-row-hero-side { display: flex; flex-direction: column; gap: 2rem; }
.arquivo-row-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-bottom: 2.5rem;
  align-items: start;
}
.arquivo-row-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

/* editorial card */
.mag-card {
  display: block;
  text-decoration: none;
  color: inherit;
}
.mag-card-photo {
  position: relative;
  overflow: hidden;
  background: var(--paper-dark);
  margin-bottom: .65rem;
  outline: 1px solid var(--rule);
}
.mag-card-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: contrast(1.06) saturate(1.1);
  transition: filter .3s;
}
.mag-card:hover .mag-card-photo img {
  filter: contrast(1.12) saturate(1.22);
}

/* aspect ratios per position */
.mag-card--hero .mag-card-photo  { aspect-ratio: 3/2; }
.mag-card--side .mag-card-photo  { aspect-ratio: 4/3; }
.mag-card--col3 .mag-card-photo  { aspect-ratio: 3/2; }
.mag-card--thumb .mag-card-photo { aspect-ratio: 3/2; }

/* frame number — kodak yellow accent */
.mag-card-frame {
  position: absolute;
  top: 6px; left: 8px;
  font-family: var(--mono);
  font-size: .46rem;
  letter-spacing: .1em;
  color: rgba(232,184,48,.8);
  pointer-events: none;
  z-index: 2;
  text-shadow: 0 1px 4px rgba(0,0,0,.5);
}
/* tiny perf accent */
.mag-card-perf {
  position: absolute;
  top: 5px; right: 6px;
  width: 9px; height: 6px;
  background: rgba(0,0,0,.35);
  border: 1px solid rgba(0,0,0,.2);
  border-radius: 1px;
  pointer-events: none;
  z-index: 2;
}

/* type badge (ensaio, etc) */
.mag-card-type {
  position: absolute;
  bottom: 6px; right: 8px;
  font-family: var(--mono);
  font-size: .42rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(244,237,216,.7);
  background: rgba(0,0,0,.45);
  padding: .15rem .4rem;
  pointer-events: none;
  z-index: 2;
}

/* caption below photo */
.mag-card-caption { padding: 0; }
.mag-card-title {
  font-family: var(--serif);
  font-size: clamp(.82rem, 1.3vw, 1rem);
  font-style: italic;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.25;
  margin-bottom: .25rem;
  border-top: 1px solid var(--rule);
  padding-top: .4rem;
}
.mag-card--hero .mag-card-title { font-size: clamp(1.05rem, 1.7vw, 1.35rem); }
.mag-card-meta {
  font-family: var(--mono);
  font-size: .5rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ink-dim);
  line-height: 1.6;
}

/* placeholder color swatches (fallback no hero_image) */
.c1 { background: linear-gradient(135deg, #1a3a5c 0%, #6a8a6a 60%, #d4621e 100%); }
.c2 { background: linear-gradient(135deg, #4a6040 0%, #8a9a5a 50%, #e8c87a 100%); }
.c3 { background: linear-gradient(135deg, #3a2820 0%, #c8341a 60%, #d4621e 100%); }
.c4 { background: linear-gradient(135deg, #2e6a9e 0%, #7aaa8a 50%, #c8a060 100%); }
.c5 { background: linear-gradient(135deg, #1a2030 0%, #1a3a5c 40%, #8aaa7a 100%); }
.c6 { background: linear-gradient(135deg, #6a4030 0%, #a87050 60%, #e8c87a 100%); }
.c7 { background: linear-gradient(135deg, #2a4020 0%, #5a8040 60%, #e8c87a 100%); }
.c8 { background: linear-gradient(135deg, #c8341a 0%, #6a3020 50%, #2a1810 100%); }

/* ── TEMAS ──────────────────────────────────────────────────────────── */
.themes-section {
  background: var(--dark-bg);
  border-top: 4px solid var(--ink);
  padding: 2.5rem 3rem 3rem;
}
.themes-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 1.8rem;
}
.themes-label {
  font-family: var(--mono);
  font-size: .56rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--accent);
  white-space: nowrap;
}
.themes-rule { flex: 1; height: 1px; background: var(--dark-border); }
.themes-list { display: flex; flex-wrap: wrap; gap: .6rem; }
.theme-pill {
  font-family: var(--mono);
  font-size: .62rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(244,237,216,.45);
  border: 1px solid var(--dark-border);
  padding: .3rem .85rem;
  text-decoration: none;
  transition: color .2s, border-color .2s, background .2s;
}
.theme-pill:hover {
  color: var(--paper);
  border-color: rgba(244,237,216,.35);
  background: rgba(255,255,255,.04);
}

/* ── FOOTER ─────────────────────────────────────────────────────────── */
footer {
  background: var(--dark-bg);
  border-top: 1px solid var(--dark-border);
  padding: 2rem 3rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.footer-logo {
  font-family: var(--mono);
  font-size: .85rem;
  letter-spacing: .15em;
  color: var(--paper);
}
.footer-logo em { color: var(--accent); font-style: normal; }
.footer-links { display: flex; gap: 1.5rem; }
.footer-links a {
  font-size: .6rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink-dim);
  text-decoration: none;
  transition: color .2s;
}
.footer-links a:hover { color: var(--paper); }
.footer-copy {
  font-size: .52rem;
  letter-spacing: .1em;
  color: var(--dark-border);
  text-transform: uppercase;
}

/* ── RESPONSIVE ─────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  nav { padding: .8rem 1.2rem; }
  .nav-right { gap: .8rem; }
  .nav-right a:not(.nav-pill) { display: none; }

  .cover-masthead { padding: 4.5rem 1.5rem 1rem; }
  .cover-headline { padding: 0 1.5rem; bottom: 30%; }
  .cover-title { font-size: clamp(2rem, 8vw, 3.5rem); }
  .cover-lines { padding: 0 1.5rem; flex-direction: column; align-items: flex-start; gap: 1rem; }
  .cover-teasers { display: none; }
  .ektar-stamp { right: 1.5rem; bottom: 5.5rem; }

  .featured-section { padding: 2.5rem 1.5rem; }
  .featured-spread { grid-template-columns: 1fr; gap: 1.5rem; }
  .featured-text-col { border-left: none; padding-left: 0; border-top: 1px solid var(--rule); padding-top: 1.5rem; }

  .arquivo-section { padding: 2rem 1.5rem 3rem; }
  .arquivo-masthead-title { font-size: clamp(2.5rem, 10vw, 4rem); }
  .arquivo-row-hero { grid-template-columns: 1fr; }
  .arquivo-row-hero-side { flex-direction: row; }
  .arquivo-row-3 { grid-template-columns: 1fr 1fr; }
  .arquivo-row-4 { grid-template-columns: 1fr 1fr; }

  .themes-section { padding: 2rem 1.5rem; }
  footer { flex-direction: column; gap: 1rem; text-align: center; padding: 2rem 1.5rem; }
  .footer-copy { display: none; }
}

@media (max-width: 480px) {
  .masthead-name { font-size: clamp(1.6rem, 7vw, 2.4rem); }
  .cover-title { font-size: clamp(1.8rem, 9vw, 2.8rem); }
  .arquivo-row-3 { grid-template-columns: 1fr; }
  .arquivo-row-hero-side { flex-direction: column; }
}
</style>
</head>
<body>

<nav>
  <a href="{{ '/' | url }}" class="logo">br<em>.</em>trombin</a>
  <div class="nav-right">
    <a href="#arquivo">arquivo</a>
    <a href="{{ '/galeria.html' | url }}">galeria</a>
    <a href="#sobre">sobre</a>
    <a href="https://naocabe.substack.com" target="_blank" class="nav-pill">Substack</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank" class="nav-pill">Instagram</a>
  </div>
</nav>

{% if collections.articles and collections.articles.length > 0 %}
{% set arts = collections.articles %}
{% set featured = arts[0] %}

<!-- ═══════════════════════ CAPA ═══════════════════════ -->
<section class="cover">

  <div class="cover-perfs" id="perfs-top"></div>

  <div class="cover-photo">
    {% if featured.data.hero_image %}
    <img src="{{ featured.data.hero_image | url }}" alt="{{ featured.data.title }}">
    {% else %}
    <div style="width:100%;height:100%;background:{{ featured.data.hero_gradient | default('linear-gradient(180deg,#1a3a5c 0%,#2e6a9e 35%,#8aaa6a 58%,#d4621e 80%,#c8341a 100%)') }}"></div>
    {% endif %}
  </div>

  <header class="cover-masthead">
    <span class="masthead-name">br<em>.</em>trombin</span>
    <div class="masthead-meta">
      Vol.&nbsp;1 &nbsp;&middot;&nbsp; No.&nbsp;{{ featured.data.frameNumber }}<br>
      {{ featured.data.date | dateLong }}<br>
      Porto Alegre RS
    </div>
  </header>

  <div class="cover-headline">
    <span class="cover-kicker">{{ featured.data.type | default("leitura") }} &nbsp;&middot;&nbsp; frame {{ featured.data.frameNumber }}</span>
    <h1 class="cover-title">{{ featured.data.title }}</h1>
    {% if featured.data.lead %}
    <p class="cover-deck">{{ featured.data.lead }}</p>
    {% endif %}
  </div>

  <div class="cover-lines">
    <a href="{{ featured.url }}" class="cover-cta">abrir texto &rarr;</a>
    <div class="cover-teasers">
      {% for article in arts %}
      {% if loop.index > 1 and loop.index <= 4 %}
      <a href="{{ article.url }}" class="cover-teaser">
        <strong>{{ article.data.title }}</strong>
        {{ article.data.date | dateLong }}
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if featured.data.location or featured.data.date or featured.data.aperture %}
  <div class="ektar-stamp">
    {% if featured.data.location %}{{ featured.data.location }}<br>{% endif %}
    {{ featured.data.date | dateStamp }}<br>
    {% if featured.data.aperture %}{{ featured.data.aperture }}&nbsp;&nbsp;{{ featured.data.speed }}{% endif %}
  </div>
  {% endif %}

  <div class="cover-perfs-bot" id="perfs-bot"></div>

</section>

<!-- ═══════════════════════ DESTAQUE ═══════════════════════ -->
<section class="featured-section">
  <div class="dept-header">
    <span class="dept-label">destaque da edição</span>
    <div class="dept-line"></div>
    <span class="dept-right">frame {{ featured.data.frameNumber }}</span>
  </div>

  <div class="featured-spread">
    <div class="featured-photo-col">
      <div class="featured-photo-frame">
        {% if featured.data.hero_image %}
        <img src="{{ featured.data.hero_image | url }}" alt="{{ featured.data.title }}">
        {% else %}
        <div class="featured-photo-placeholder {{ featured.data.colorClass }}"></div>
        {% endif %}
      </div>
      <p class="featured-caption">
        {% if featured.data.location %}{{ featured.data.location }} &nbsp;&middot;&nbsp; {% endif %}
        {{ featured.data.date | dateStamp }}
        {% if featured.data.camera %} &nbsp;&middot;&nbsp; {{ featured.data.camera }}{% endif %}
      </p>
    </div>

    <div class="featured-text-col">
      <span class="featured-eyebrow">{{ featured.data.type | default("leitura") }} &nbsp;&middot;&nbsp; {{ featured.data.date | dateLong }}</span>
      <h2 class="featured-title">{{ featured.data.title }}</h2>
      {% if featured.data.lead %}
      <p class="featured-lead">{{ featured.data.lead }}</p>
      {% endif %}
      <span class="featured-byline">por br.trombin</span>
      <a href="{{ featured.url }}" class="btn-mag">abrir texto &rarr;</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════ ARQUIVO ═══════════════════════ -->
<section class="arquivo-section" id="arquivo">

  <div class="arquivo-masthead">
    <div class="arquivo-masthead-title">Arquivo</div>
    <div class="arquivo-masthead-meta">
      br.trombin &nbsp;&middot;&nbsp; 2024–2025<br>
      {{ arts.length }} texto{% if arts.length != 1 %}s{% endif %} publicado{% if arts.length != 1 %}s{% endif %}
    </div>
  </div>

  {# ── Linha 1: arts[1] grande + arts[2] e arts[3] empilhados ── #}
  {% if arts[1] %}
  <div class="arquivo-row-hero">
    <a class="mag-card mag-card--hero" href="{{ arts[1].url }}">
      <div class="mag-card-photo">
        {% if arts[1].data.hero_image %}
        <img src="{{ arts[1].data.hero_image | url }}" alt="{{ arts[1].data.title }}">
        {% else %}
        <div class="{{ arts[1].data.colorClass }}" style="width:100%;height:100%"></div>
        {% endif %}
        <span class="mag-card-frame">{{ arts[1].data.frameNumber }}</span>
        <span class="mag-card-perf"></span>
        {% if arts[1].data.type and arts[1].data.type != 'leitura' %}
        <span class="mag-card-type">{{ arts[1].data.type }}</span>
        {% endif %}
      </div>
      <div class="mag-card-caption">
        <p class="mag-card-title">{{ arts[1].data.title }}</p>
        <p class="mag-card-meta">{{ arts[1].data.date | dateLong }}{% if arts[1].data.location %} &nbsp;&middot;&nbsp; {{ arts[1].data.location | locShort }}{% endif %}</p>
      </div>
    </a>

    <div class="arquivo-row-hero-side">
      {% if arts[2] %}
      <a class="mag-card mag-card--side" href="{{ arts[2].url }}">
        <div class="mag-card-photo">
          {% if arts[2].data.hero_image %}
          <img src="{{ arts[2].data.hero_image | url }}" alt="{{ arts[2].data.title }}">
          {% else %}
          <div class="{{ arts[2].data.colorClass }}" style="width:100%;height:100%"></div>
          {% endif %}
          <span class="mag-card-frame">{{ arts[2].data.frameNumber }}</span>
          <span class="mag-card-perf"></span>
        </div>
        <div class="mag-card-caption">
          <p class="mag-card-title">{{ arts[2].data.title }}</p>
          <p class="mag-card-meta">{{ arts[2].data.date | dateLong }}</p>
        </div>
      </a>
      {% endif %}
      {% if arts[3] %}
      <a class="mag-card mag-card--side" href="{{ arts[3].url }}">
        <div class="mag-card-photo">
          {% if arts[3].data.hero_image %}
          <img src="{{ arts[3].data.hero_image | url }}" alt="{{ arts[3].data.title }}">
          {% else %}
          <div class="{{ arts[3].data.colorClass }}" style="width:100%;height:100%"></div>
          {% endif %}
          <span class="mag-card-frame">{{ arts[3].data.frameNumber }}</span>
          <span class="mag-card-perf"></span>
        </div>
        <div class="mag-card-caption">
          <p class="mag-card-title">{{ arts[3].data.title }}</p>
          <p class="mag-card-meta">{{ arts[3].data.date | dateLong }}</p>
        </div>
      </a>
      {% endif %}
    </div>
  </div>
  {% endif %}

  {# ── Linha 2: arts[4], [5], [6] em 3 colunas ── #}
  {% if arts[4] %}
  <div class="arquivo-row-3">
    {% for idx in [4, 5, 6] %}
    {% if arts[idx] %}
    <a class="mag-card mag-card--col3" href="{{ arts[idx].url }}">
      <div class="mag-card-photo">
        {% if arts[idx].data.hero_image %}
        <img src="{{ arts[idx].data.hero_image | url }}" alt="{{ arts[idx].data.title }}">
        {% else %}
        <div class="{{ arts[idx].data.colorClass }}" style="width:100%;height:100%"></div>
        {% endif %}
        <span class="mag-card-frame">{{ arts[idx].data.frameNumber }}</span>
        <span class="mag-card-perf"></span>
        {% if arts[idx].data.type and arts[idx].data.type != 'leitura' %}
        <span class="mag-card-type">{{ arts[idx].data.type }}</span>
        {% endif %}
      </div>
      <div class="mag-card-caption">
        <p class="mag-card-title">{{ arts[idx].data.title }}</p>
        <p class="mag-card-meta">{{ arts[idx].data.date | dateLong }}{% if arts[idx].data.location %} &nbsp;&middot;&nbsp; {{ arts[idx].data.location | locShort }}{% endif %}</p>
      </div>
    </a>
    {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  {# ── Linhas 3+: arts[7] em diante, 4 colunas ── #}
  {% for row in arts | skip(7) | chunk(4) %}
  <div class="arquivo-row-4">
    {% for article in row %}
    <a class="mag-card mag-card--thumb" href="{{ article.url }}">
      <div class="mag-card-photo">
        {% if article.data.hero_image %}
        <img src="{{ article.data.hero_image | url }}" alt="{{ article.data.title }}">
        {% else %}
        <div class="{{ article.data.colorClass }}" style="width:100%;height:100%"></div>
        {% endif %}
        <span class="mag-card-frame">{{ article.data.frameNumber }}</span>
        <span class="mag-card-perf"></span>
      </div>
      <div class="mag-card-caption">
        <p class="mag-card-title">{{ article.data.title }}</p>
        <p class="mag-card-meta">{{ article.data.date | dateYM }}</p>
      </div>
    </a>
    {% endfor %}
  </div>
  {% endfor %}

</section>

{% else %}
<!-- placeholder quando não há artigos -->
<section class="cover">
  <div class="cover-perfs" id="perfs-top"></div>
  <div class="cover-photo">
    <div style="width:100%;height:100%;background:linear-gradient(180deg,#1a3a5c 0%,#2e6a9e 35%,#8aaa6a 58%,#d4621e 80%,#c8341a 100%)"></div>
  </div>
  <header class="cover-masthead">
    <span class="masthead-name">br<em>.</em>trombin</span>
  </header>
  <div class="cover-headline">
    <h1 class="cover-title">O que não<br>coube aqui<br>ficou em mim</h1>
  </div>
  <div class="cover-perfs-bot" id="perfs-bot"></div>
</section>
{% endif %}

<!-- ═══════════════════════ TEMAS ═══════════════════════ -->
{% set allThemes = collections.articles | uniqueThemes %}
{% if allThemes and allThemes.length > 0 %}
<section class="themes-section">
  <div class="themes-header">
    <span class="themes-label">explorar por tema</span>
    <div class="themes-rule"></div>
  </div>
  <div class="themes-list">
    {% for theme in allThemes %}
    <a href="{{ '/galeria.html' | url }}?theme={{ theme }}" class="theme-pill">{{ theme }}</a>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- ═══════════════════════ FOOTER ═══════════════════════ -->
<footer id="sobre">
  <span class="footer-logo">br<em>.</em>trombin</span>
  <div class="footer-links">
    <a href="https://naocabe.substack.com" target="_blank">Não Cabia</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank">Instagram</a>
    <a href="#sobre">sobre</a>
  </div>
  <span class="footer-copy">Kodak Ektar 100 &nbsp;&middot;&nbsp; Porto Alegre RS &nbsp;&middot;&nbsp; 2024&ndash;2025</span>
</footer>

<script>
function makePerfs(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const n = Math.ceil(window.innerWidth / 32) + 2;
  el.innerHTML = Array(n).fill('<div class="perf"></div>').join('');
}
makePerfs('perfs-top');
makePerfs('perfs-bot');
window.addEventListener('resize', () => {
  makePerfs('perfs-top');
  makePerfs('perfs-bot');
});
</script>
</body>
</html>
