---
permalink: /
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>tromb.in</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Playfair+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --black: #1a2a1e;
  --film-black: #162318;
  --ektar-red: #c8341a;
  --ektar-orange: #d4621e;
  --ektar-blue: #1a3a5c;
  --ektar-sky: #2e6a9e;
  --ektar-warm: #e8c87a;
  --strip-bg: #2a1e10;
  --frame-border: #0d0a05;
  --perf-hole: #000;
  --text-dim: #7a6a52;
  --cream: #f0e8d0;
  --mono: 'Share Tech Mono', monospace;
  --serif: 'Playfair Display', serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--black);
  color: var(--cream);
  font-family: var(--mono);
  min-height: 100vh;
  overflow-x: hidden;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 999;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  opacity: .06;
  mix-blend-mode: screen;
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: .9rem 2rem;
  background: rgba(26,42,30,.94);
  backdrop-filter: blur(6px);
  border-bottom: 1px solid #243a28;
}

.logo {
  font-family: var(--mono);
  font-size: .95rem;
  letter-spacing: .2em;
  color: var(--cream);
  text-decoration: none;
}
.logo em { color: var(--ektar-red); font-style: normal; }

.nav-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.nav-right a {
  font-family: var(--mono);
  font-size: .65rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-decoration: none;
  transition: color .2s;
}
.nav-right a:hover { color: var(--cream); }

.nav-pill {
  border: 1px solid #333;
  padding: .22rem .7rem;
  color: var(--ektar-red) !important;
  border-color: var(--ektar-red) !important;
}

/* HERO */
.hero {
  padding-top: 52px;
  background: var(--strip-bg);
  position: relative;
  overflow: hidden;
}

.perfs {
  height: 22px;
  background: var(--strip-bg);
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 4px;
  position: relative;
  z-index: 2;
}

.perf {
  width: 14px;
  height: 10px;
  background: var(--perf-hole);
  border: 1px solid #1a1408;
  border-radius: 2px;
  margin-right: 18px;
  flex-shrink: 0;
}

.hero-frame {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  min-height: calc(100vh - 100px);
  border-top: 2px solid var(--frame-border);
  border-bottom: 2px solid var(--frame-border);
  position: relative;
}

.frame-label {
  position: absolute;
  bottom: -20px;
  left: 12px;
  font-size: .58rem;
  letter-spacing: .22em;
  color: #ff8c00;
  opacity: .85;
  font-family: var(--mono);
  z-index: 10;
}

.hero-photo {
  position: relative;
  overflow: hidden;
  background: #1a2e20;
  border-right: 2px solid var(--frame-border);
}

.hero-photo-inner {
  width: 100%;
  height: 100%;
  min-height: calc(100vh - 100px);
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1.5rem;
  filter: contrast(1.12) saturate(1.3);
}

.hero-photo-inner img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(1.1) saturate(1.25);
  display: block;
}

.ektar-stamp {
  position: absolute;
  bottom: 12px;
  right: 14px;
  font-family: var(--mono);
  font-size: .62rem;
  color: #ff8c00;
  letter-spacing: .12em;
  text-shadow: 0 0 8px rgba(255,140,0,.6);
  z-index: 2;
  line-height: 1.5;
  text-align: right;
}

.hero-info {
  padding: 3.5rem 3rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--strip-bg);
  position: relative;
}

.strip-index {
  font-size: .6rem;
  letter-spacing: .28em;
  color: var(--ektar-red);
  text-transform: uppercase;
  margin-bottom: 2rem;
}

.hero-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.6vw, 3.6rem);
  line-height: 1.08;
  color: var(--cream);
  font-style: normal;
  font-weight: 700;
  margin-bottom: 1.8rem;
  letter-spacing: -.01em;
}

.hero-excerpt {
  font-family: var(--serif);
  font-size: .9rem;
  line-height: 1.85;
  color: #b0a080;
  max-width: 36ch;
  margin-bottom: 2.5rem;
  font-style: italic;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2.5rem;
  font-size: .62rem;
  letter-spacing: .15em;
  color: var(--text-dim);
  text-transform: uppercase;
}

.meta-dot {
  width: 3px;
  height: 3px;
  background: var(--ektar-red);
  border-radius: 50%;
}

.btn-read {
  display: inline-block;
  font-family: var(--mono);
  font-size: .65rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--black);
  background: var(--ektar-red);
  padding: .7rem 1.6rem;
  text-decoration: none;
  align-self: flex-start;
  transition: background .2s;
}
.btn-read:hover { background: var(--ektar-orange); }

.exposure-data {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  font-size: .55rem;
  letter-spacing: .15em;
  color: #3a3020;
  writing-mode: vertical-rl;
  text-transform: uppercase;
  line-height: 2;
}

@keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
.hero-info > * { animation: fadeUp .7s ease both; }
.strip-index { animation-delay: .1s; }
.hero-title { animation-delay: .22s; }
.hero-excerpt { animation-delay: .35s; }
.meta-row { animation-delay: .44s; }
.btn-read { animation-delay: .54s; }

/* CONTACT SHEET */
.sheet-header {
  padding: 3rem 2rem 1.2rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  border-top: 1px solid #243a28;
}

.sheet-header h2 {
  font-family: var(--mono);
  font-size: .62rem;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--ektar-red);
  white-space: nowrap;
}

.sheet-header-line {
  flex: 1;
  height: 1px;
  background: #2a2218;
}

.sheet-header-right {
  font-size: .58rem;
  letter-spacing: .15em;
  color: #3a3020;
  text-transform: uppercase;
}

.contact-sheet {
  background: var(--black);
  padding: 1.5rem 2rem 3rem;
  border-top: 2px solid #000;
  border-bottom: 2px solid #000;
}

.strip-row {
  overflow-x: hidden;
  margin-bottom: 1.2rem;
}

.strip-inner {
  display: flex;
  flex-direction: column;
}

/* faixa de furinhos horizontal — topo e base da tira */
.strip-perfs-h {
  height: 18px;
  background: #2a1e10;
  flex-shrink: 0;
  position: relative;
}
.strip-perfs-h::before {
  content: '';
  position: absolute;
  top: 20%;
  left: 0;
  right: 0;
  height: 60%;
  background: repeating-linear-gradient(
    to right,
    transparent 0, transparent 5px,
    #000 5px, #000 17px,
    transparent 17px, transparent 22px
  );
}

.strip-frames {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 5px;
  background: #0c0905;
  padding: 6px;
}

.film-frame {
  position: relative;
  aspect-ratio: 3/2;
  overflow: hidden;
  background: #0f1a12;
  cursor: pointer;
  text-decoration: none;
  display: block;
}

.film-frame:hover .frame-overlay { opacity: 1; }
.film-frame:hover .frame-ph img { filter: contrast(1.2) saturate(1.4) brightness(.82); }

.frame-ph {
  width: 100%;
  height: 100%;
}

.frame-ph img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: contrast(1.08) saturate(1.15);
  transition: filter .35s;
}

.frame-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(transparent 40%, rgba(0,0,0,.75));
  opacity: 0;
  transition: opacity .3s;
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
  padding: .5rem .4rem;
  z-index: 3;
}

.frame-title-overlay {
  font-family: var(--mono);
  font-size: .5rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--cream);
  line-height: 1.4;
  text-shadow: 0 1px 6px rgba(0,0,0,.9);
}

.frame-idx {
  position: absolute;
  top: 5px;
  left: 6px;
  font-size: .46rem;
  color: rgba(255,140,0,.5);
  font-family: var(--mono);
  letter-spacing: .06em;
  pointer-events: none;
  z-index: 2;
}

.frame-meta {
  position: absolute;
  bottom: 5px;
  left: 6px;
  font-family: var(--mono);
  font-size: clamp(.3rem, .38vw, .38rem);
  color: rgba(212,98,30,.8);
  letter-spacing: .07em;
  line-height: 1.5;
  text-shadow: 0 0 6px rgba(0,0,0,.95);
  pointer-events: none;
  z-index: 2;
}

/* placeholder color swatches */
.c1 { background: linear-gradient(135deg, var(--ektar-blue) 0%, #6a8a6a 60%, var(--ektar-orange) 100%); }
.c2 { background: linear-gradient(135deg, #4a6040 0%, #8a9a5a 50%, var(--ektar-warm) 100%); }
.c3 { background: linear-gradient(135deg, #3a2820 0%, var(--ektar-red) 60%, var(--ektar-orange) 100%); }
.c4 { background: linear-gradient(135deg, var(--ektar-sky) 0%, #7aaa8a 50%, #c8a060 100%); }
.c5 { background: linear-gradient(135deg, #1a2030 0%, var(--ektar-blue) 40%, #8aaa7a 100%); }
.c6 { background: linear-gradient(135deg, #6a4030 0%, #a87050 60%, var(--ektar-warm) 100%); }
.c7 { background: linear-gradient(135deg, #2a4020 0%, #5a8040 60%, var(--ektar-warm) 100%); }
.c8 { background: linear-gradient(135deg, var(--ektar-red) 0%, #6a3020 50%, #2a1810 100%); }

footer {
  border-top: 1px solid #243a28;
  padding: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-logo {
  font-family: var(--mono);
  font-size: .85rem;
  letter-spacing: .15em;
  color: var(--cream);
}
.footer-logo em { color: var(--ektar-red); font-style: normal; }

.footer-links { display: flex; gap: 1.5rem; }
.footer-links a {
  font-size: .6rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-decoration: none;
  transition: color .2s;
}
.footer-links a:hover { color: var(--cream); }

.footer-copy {
  font-size: .52rem;
  letter-spacing: .1em;
  color: #2a3a2c;
  text-transform: uppercase;
}

@media (max-width: 768px) {
  nav { padding: .8rem 1.2rem; }
  .nav-right { gap: .8rem; }
  .nav-right a:not(.nav-pill) { display: none; }
  .hero-frame { grid-template-columns: 1fr; min-height: auto; }
  .hero-photo { border-right: none; border-bottom: 2px solid var(--frame-border); }
  .hero-photo-inner { min-height: 56vw; }
  .hero-info { padding: 2rem 1.5rem; }
  .exposure-data { display: none; }
  .contact-sheet { padding: 1rem 0 2rem; }
  /* a tira inteira (perfs + frames) rola como unidade */
  .strip-row {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .strip-row::-webkit-scrollbar { display: none; }
  .strip-inner {
    display: inline-flex;
    flex-direction: column;
    min-width: max-content;
  }
  .strip-perfs-h {
    width: 100%;
  }
  .strip-frames {
    grid-template-columns: repeat(4, 70vw);
    gap: 4px;
    padding: 4px;
  }
  .strip-perfs-h::before {
    background: repeating-linear-gradient(
      to right,
      transparent 0, transparent 5px,
      #000 5px, #000 13px,
      transparent 13px, transparent 18px
    );
  }
  footer { flex-direction: column; gap: 1rem; text-align: center; }
  .footer-copy { display: none; }
}
</style>
</head>
<body>

<nav>
  <a href="{{ '/' | url }}" class="logo">tromb<em>.</em>in</a>
  <div class="nav-right">
    <a href="#arquivo">arquivo</a>
    <a href="{{ '/galeria.html' | url }}">galeria</a>
    <a href="#sobre">sobre</a>
    <a href="https://naocabe.substack.com" target="_blank" class="nav-pill">Substack</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank" class="nav-pill">Instagram</a>
  </div>
</nav>

{% if collections.articles and collections.articles.length > 0 %}
{% set featured = collections.articles[0] %}

<section class="hero">
  <div class="perfs" id="perfs-top"></div>

  <div class="hero-frame">
    <div class="hero-photo">
      <div class="hero-photo-inner" {% if not featured.data.hero_image %}style="background:{{ featured.data.hero_gradient | default('linear-gradient(180deg, #1a3a5c 0%, #2e6a9e 35%, #8aaa6a 58%, #d4621e 80%, #c8341a 100%)') }}"{% endif %}>
        {% if featured.data.hero_image %}
        <img src="{{ featured.data.hero_image | url }}" alt="{{ featured.data.title }}">
        {% endif %}
        <div class="ektar-stamp">
          {{ featured.data.location }}<br>
          {{ featured.data.date | dateStamp }}<br>
          {{ featured.data.aperture }}&nbsp;&nbsp;{{ featured.data.speed }}
        </div>
      </div>
    </div>

    <div class="hero-info">
      <p class="strip-index">tromb.in &mdash; frame {{ featured.data.frameNumber }}</p>
      <h1 class="hero-title">{{ featured.data.title }}</h1>
      {% if featured.data.lead %}
      <p class="hero-excerpt">{{ featured.data.lead }}</p>
      {% endif %}
      <div class="meta-row">
        <span>{{ featured.data.date | dateLong }}</span>
        <span class="meta-dot"></span>
        <span>{{ featured.data.type | default("leitura") }}</span>
        <span class="meta-dot"></span>
        <span>{{ featured.data.camera }}</span>
      </div>
      <a href="{{ featured.url }}" class="btn-read">abrir texto</a>
      <div class="exposure-data">{{ featured.data.film }} &nbsp;&middot;&nbsp; ISO 100</div>
    </div>

    <span class="frame-label">▷ {{ featured.data.frameNumber }} &nbsp; {{ featured.data.film }} &nbsp; 99exp</span>
  </div>

  <div class="perfs" id="perfs-bot"></div>
</section>

<div class="sheet-header" id="arquivo">
  <h2>contact sheet</h2>
  <div class="sheet-header-line"></div>
  <span class="sheet-header-right">tromb.in &nbsp; 2024&ndash;2025</span>
</div>

<div class="contact-sheet">
  {% for chunk in collections.articles | chunk(4) %}
  <div class="strip-row">
    <div class="strip-inner">
      <div class="strip-perfs-h"></div>
      <div class="strip-frames">
        {% for article in chunk %}
        <a class="film-frame" href="{{ article.url }}">
          {% if article.data.hero_image %}
          <div class="frame-ph"><img src="{{ article.data.hero_image | url }}" alt="{{ article.data.title }}"></div>
          {% else %}
          <div class="frame-ph {{ article.data.colorClass }}"></div>
          {% endif %}
          <span class="frame-idx">{{ article.data.frameNumber }}</span>
          <div class="frame-meta">
            {{ article.data.location | locShort }}<br>{{ article.data.date | dateYM }}
          </div>
          <div class="frame-overlay">
            <span class="frame-title-overlay">{{ article.data.title }}</span>
          </div>
        </a>
        {% endfor %}
      </div>
      <div class="strip-perfs-h"></div>
    </div>
  </div>
  {% endfor %}
</div>

{% else %}
{# Placeholder quando não há artigos ainda #}
<section class="hero">
  <div class="perfs" id="perfs-top"></div>
  <div class="hero-frame">
    <div class="hero-photo">
      <div class="hero-photo-inner" style="background:linear-gradient(180deg,#1a3a5c 0%,#2e6a9e 35%,#8aaa6a 58%,#d4621e 80%,#c8341a 100%)">
      </div>
    </div>
    <div class="hero-info">
      <p class="strip-index">tromb.in &mdash; frame 000</p>
      <h1 class="hero-title">O que não<br>coube aqui<br>ficou em mim</h1>
    </div>
  </div>
  <div class="perfs" id="perfs-bot"></div>
</section>
{% endif %}

<footer id="sobre">
  <span class="footer-logo">tromb<em>.</em>in</span>
  <div class="footer-links">
    <a href="https://naocabe.substack.com" target="_blank">Não Cabia</a>
    <a href="https://www.instagram.com/brtrombin" target="_blank">Instagram</a>
    <a href="#sobre">sobre</a>
  </div>
  <span class="footer-copy">Kodak Ektar 100 &nbsp;&middot;&nbsp; Porto Alegre RS &nbsp;&middot;&nbsp; 2024&ndash;2025</span>
</footer>

<script>
function makePerfs(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const n = Math.ceil(window.innerWidth / 32) + 2;
  el.innerHTML = Array(n).fill('<div class="perf"></div>').join('');
}
makePerfs('perfs-top');
makePerfs('perfs-bot');
window.addEventListener('resize', () => { makePerfs('perfs-top'); makePerfs('perfs-bot'); });

// Auto-scroll suave nas tiras — apenas mobile
(function() {
  if (window.innerWidth > 768) return;

  const SPEED = 0.4; // px por frame (~24px/s em 60fps)
  const PAUSE_AFTER_TOUCH = 3000; // ms de pausa após interação

  document.querySelectorAll('.strip-row').forEach(row => {
    let rafId = null;
    let paused = false;
    let resumeTimer = null;
    let visible = false;

    function scroll() {
      if (!paused && visible) {
        const inner = row.querySelector('.strip-inner') || row;
        const maxScroll = inner.scrollWidth - row.clientWidth;
        if (row.scrollLeft >= maxScroll) {
          // chegou no fim: pausa 1s e volta pro início suavemente
          paused = true;
          setTimeout(() => {
            row.scrollTo({ left: 0, behavior: 'smooth' });
            setTimeout(() => { paused = false; }, 600);
          }, 1000);
        } else {
          row.scrollLeft += SPEED;
        }
      }
      rafId = requestAnimationFrame(scroll);
    }

    function pauseTemporarily() {
      paused = true;
      clearTimeout(resumeTimer);
      resumeTimer = setTimeout(() => { paused = false; }, PAUSE_AFTER_TOUCH);
    }

    row.addEventListener('touchstart', pauseTemporarily, { passive: true });
    row.addEventListener('mouseenter', () => { paused = true; });
    row.addEventListener('mouseleave', () => { paused = false; });

    const observer = new IntersectionObserver(entries => {
      visible = entries[0].isIntersecting;
      if (visible && !rafId) rafId = requestAnimationFrame(scroll);
    }, { threshold: 0.3 });

    observer.observe(row);
  });
})();
</script>
</body>
</html>
